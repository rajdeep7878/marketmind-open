root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,toml}]
indent_size = 4

[*.{ts,tsx,js,jsx,json,jsonc,yml,yaml,md,html,css}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
