{
  "schema_version": "2.0",
  "name": "Regime Trend-Following",
  "description": "Long BTC 4h while a close>EMA200 regime is latched on and EMA20 crosses above EMA50; ATR stop.",
  "instrument": { "symbol": "BTC/USDT", "exchange": "binance", "quote_currency": "USDT" },
  "primary_timeframe": "4h",
  "direction": "long",
  "entry": {
    "condition": {
      "type": "and",
      "conditions": [
        {
          "type": "regime_state",
          "enter_when": {
            "type": "crossover",
            "series": { "kind": "price", "field": "close" },
            "threshold": { "kind": "indicator", "name": "ema", "params": { "period": 200 } },
            "direction": "above"
          },
          "exit_when": {
            "type": "crossover",
            "series": { "kind": "price", "field": "close" },
            "threshold": { "kind": "indicator", "name": "ema", "params": { "period": 200 } },
            "direction": "below"
          },
          "initial": false
        },
        {
          "type": "crossover",
          "series": { "kind": "indicator", "name": "ema", "params": { "period": 20 } },
          "threshold": { "kind": "indicator", "name": "ema", "params": { "period": 50 } },
          "direction": "above"
        }
      ]
    },
    "order_type": "market"
  },
  "exit": {
    "exits": [
      { "type": "stop_loss", "method": { "kind": "atr_multiple", "atr_period": 14, "mult": 2.0 } }
    ]
  }
}
