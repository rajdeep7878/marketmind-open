{
  "schema_version": "2.0",
  "name": "Ratcheting Trailing Breakout",
  "description": "Long BTC 4h on a 20-bar high breakout; exit when close falls 10% below the highest close since entry.",
  "instrument": { "symbol": "BTC/USDT", "exchange": "binance", "quote_currency": "USDT" },
  "primary_timeframe": "4h",
  "direction": "long",
  "entry": {
    "condition": {
      "type": "crossover",
      "series": { "kind": "price", "field": "close" },
      "threshold": {
        "kind": "lagged",
        "expression": {
          "kind": "indicator",
          "name": "highest",
          "params": { "period": 20, "source": "high" }
        },
        "bars_ago": 1
      },
      "direction": "above"
    },
    "order_type": "market"
  },
  "exit": {
    "exits": [
      {
        "type": "condition",
        "condition": {
          "type": "compare",
          "left": { "kind": "price", "field": "close" },
          "op": "<",
          "right": {
            "kind": "scaled",
            "expression": {
              "kind": "ratchet",
              "source": { "kind": "price", "field": "close" },
              "extremum": "max",
              "reset": "per_trade"
            },
            "factor": 0.9
          }
        }
      },
      { "type": "stop_loss", "method": { "kind": "percent", "value": 0.15 } }
    ]
  }
}
