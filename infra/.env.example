# Copy to .env at the repo root and adjust.
# docker compose reads .env from the working directory automatically.
#
# Each section names which service reads each variable so you can
# trim this down per-environment. Defaults below are tuned for
# LOCAL DEV: paper-only trader on a £1000 account, BTC/USDT +
# ETH/USDT at 4h, no Telegram delivery, no admin auth.

# ---- Runtime (api + worker + trader_worker) -------------------------------

ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- API HTTP server -----------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated allow-list for browser preflight. Local web dev runs
# on :3000, the api on :8000. Both must be in here.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Per-IP /content/ingest cap in a rolling 24h window.
# Set to 0 to disable (intended for local single-user dev only —
# do NOT set 0 in any deployed environment).
RATE_LIMIT_INGEST_PER_DAY=5

# Daily Anthropic spend ceiling in GBP. Set to 0 to disable.
DAILY_COST_CAP_GBP=5.0
GBP_USD_RATE=1.27

# HTTP Basic auth for /admin/* AND /trader/admin/*. Leaving these
# empty makes every /admin/* call return 503; the trader-admin
# endpoints (enable / disable / approve_paper) also 503 in that case.
# Set them to real values before approving any strategy.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---- Postgres ------------------------------------------------------------

POSTGRES_USER=marketmind
POSTGRES_PASSWORD=marketmind_dev
POSTGRES_DB=marketmind

# Inside the docker compose network: host is the service name "postgres".
# When running api/worker/trader on the host (uv run …), point at
# localhost:5432 — change `postgres` → `localhost` in the URL.
DATABASE_URL=postgresql://marketmind:marketmind_dev@postgres:5432/marketmind

# ---- Redis ---------------------------------------------------------------

# Same hostname rule as Postgres — "redis" inside containers,
# "localhost" when running services on the host.
REDIS_URL=redis://redis:6379/0

# Queue the general worker consumes (Phase 2 extraction jobs, etc.).
# The trader_worker uses TRADER_QUEUE_NAME, not this.
RQ_QUEUE_NAME=default

# ---- Storage -------------------------------------------------------------

# Volume mounted into the worker / api containers. Holds yt-dlp
# downloads + faster-whisper transcripts.
DATA_DIR=/data

# ---- LLM (extraction; the TRADER never reads this) -----------------------

# Required for Phase 2.2 extractions only. The trader v1 runs with
# this unset — its decision path is LLM-free (verified by
# test_trader_no_llm.py).
ANTHROPIC_API_KEY=

# ---- Web (Next.js) ------------------------------------------------------

# Browser-facing API URL. Inlined into the client JS at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side API URL Next.js uses for SSR / route handlers inside
# the compose network. Set to http://api:8000 when running web in
# Docker; unset when running web on the host (it'll fall back to
# NEXT_PUBLIC_API_URL).
API_URL_INTERNAL=http://api:8000

NEXT_TELEMETRY_DISABLED=1

# Optional analytics. Leave unset to skip the Plausible snippet.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=

# ---- Trader v1 (trader_worker only) -------------------------------------
#
# All TRADER_* vars are read by `marketmind_workers.trader.config`.
# Defaults match TraderSettings in that file; values shown here are
# the SAFE local-paper-trading defaults.

# THE PAPER-ONLY KILL SWITCH. The runner asserts this is literally
# "false" (case-insensitive) before doing anything else. Any other
# value crashes the process at boot. v1 has no live-trading code path.
TRADER_ALLOW_LIVE=false

# Dedicated queue so a long extraction job on `default` can't head-
# of-line block a signal-execution cycle.
TRADER_QUEUE_NAME=trader_default

# The ingestion loop pulls candles for the union of these and every
# enabled strategy version's symbols/timeframes. Comma-separated.
TRADER_SYMBOLS=BTC/USDT,ETH/USDT
TRADER_TIMEFRAMES=4h,1h,15m

# Paper account starting cash. Decimal — quote currency is GBP for
# operator-facing reporting; the bot still trades USDT-quoted pairs
# (conversion is a static reporting transform, not a real FX trade).
TRADER_STARTING_CASH_GBP=1000

# Risk caps. Decimal proportions: 0.01 == 1%.
TRADER_MAX_RISK_PER_TRADE_PCT=0.01
TRADER_MAX_PORTFOLIO_RISK_PCT=0.05
TRADER_MAX_DAILY_LOSS_PCT=0.02
TRADER_MAX_WEEKLY_LOSS_PCT=0.05
TRADER_MAX_DRAWDOWN_PCT=0.10

# Stale-data threshold. The risk manager blocks signals whose latest
# candle is older than this — 600s is a generous default for 4h
# timeframes. Tighten when running on 1h / 15m.
TRADER_DATA_STALENESS_SECONDS=600

# Default fee + slippage applied when a strategy version doesn't
# override them. 10 bps = 0.10% — matches the MarketMind backtest
# engine's DEFAULT_COST_MODEL so paper results align with the
# approving backtest by default.
TRADER_DEFAULT_FEE_BPS=10
TRADER_DEFAULT_SLIPPAGE_BPS=10

# Telegram delivery. BOTH must be set for HTTP delivery to happen;
# leaving either empty makes the alert dispatcher write the row to
# trader_alerts with delivered=False and skip the network call —
# useful for local dev where you don't need notifications.
# To use Telegram: create a bot via @BotFather, paste its token,
# and DM the bot once so chat_id is discoverable via getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
