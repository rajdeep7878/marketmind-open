web/src/types/generated/schemas.ts

# Market data cache — never commit OHLCV parquet files
data/*
!data/.gitkeep

# FTR (Phase D) — OHLCV caches, L1/L2 recordings, model artifacts and
# validation outputs all live under data/ftr/ (covered by data/* above;
# listed for clarity). KILLSWITCH is the paper-trader halt sentinel.
data/ftr/
KILLSWITCH

