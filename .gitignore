*.key

# Claude Code per-user settings (project-wide settings.json IS committed)
.claude/settings.local.json
.claude/

# Public-repo hardening: market-data files are redistribution-restricted by
# exchange ToS and must never be committed — regenerate via the fetch
# scripts (workers/scripts/fetch_perp_fixture.py, marketmind_workers.ftr.data.fetch_all,
# workers/scripts/fetch_eurusd_2025_fixture.py).
*.parquet
tests/fixtures/market/
# ML model artifacts are reproducible from the validation runner; never commit.
*.pkl
*.joblib
*.ubj
